---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  coverImageUrl?: string;
  coverImageWidth?: number;
  coverImageHeight?: number;
}

const { title, description, coverImageUrl, coverImageWidth, coverImageHeight } = Astro.props;
const baseUrl = Astro.site || Astro.url?.origin;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <!-- Open Graph / Social share -->
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="article" />
    {coverImageUrl && baseUrl && (
      <>
        <meta property="og:image" content={new URL(coverImageUrl, baseUrl).href} />
        {coverImageWidth && <meta property="og:image:width" content={String(coverImageWidth)} />}
        {coverImageHeight && <meta property="og:image:height" content={String(coverImageHeight)} />}
        <meta property="og:image:type" content="image/png" />
      </>
    )}
    <meta name="twitter:card" content={coverImageUrl ? "summary_large_image" : "summary"} />

    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1 max-w-3xl mx-auto px-6 py-12 w-full">
      <slot />
    </main>
    <Footer />
  </body>
</html>
