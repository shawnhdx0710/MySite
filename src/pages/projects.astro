---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'NBA Shot Chart',
    description: 'Interactive shot chart visualization built with React and Canvas, embedded via MDX.',
    url: '/blog/first-post',
    tags: ['React', 'Canvas', 'NBA'],
  },
];
---

<BaseLayout
  title="Projects — Shawn Han"
  description="Projects and portfolio work by Shawn Han."
>
  <div class="space-y-10">
    <div>
      <h1 class="font-serif text-4xl font-semibold tracking-tight">Projects</h1>
      <p class="mt-2 text-soft-ink">
        Things I've built at the intersection of data and sports.
      </p>
    </div>

    <div class="grid gap-6">
      {
        projects.map((p) => (
          <a href={p.url} class="card group block p-6">
            <h2 class="font-serif text-xl font-semibold group-hover:text-accent transition-colors">
              {p.title}
            </h2>
            <p class="mt-2 text-sm text-soft-ink leading-relaxed">
              {p.description}
            </p>
            <div class="flex gap-2 mt-4">
              {p.tags.map((t) => (
                <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 text-soft-ink">
                  {t}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>
