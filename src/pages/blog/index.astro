---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
---

<BaseLayout
  title="Blog — Shawn Han"
  description="Sports analytics and data science writing by Shawn Han."
>
  <div class="space-y-10">
    <div>
      <h1 class="font-serif text-4xl font-semibold tracking-tight">Blog</h1>
      <p class="mt-2 text-soft-ink">
        Essays on sports analytics, statistics, and machine learning.
      </p>
    </div>

    {
      posts.length === 0 ? (
        <p class="text-soft-ink italic">No posts yet.</p>
      ) : (
        <div class="grid gap-8">
          {posts
            .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
            .map((post) => (
              <a href={`/blog/${post.id}`} class="card group block">
                {post.data.coverImage && (
                  <img
                    src={post.data.coverImage.src}
                    alt={post.data.title}
                    class="w-full h-52 object-cover"
                  />
                )}
                <div class="p-6">
                  <p class="text-xs text-soft-ink tracking-wide uppercase">
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </p>
                  <h2 class="font-serif text-xl font-semibold mt-2 group-hover:text-accent transition-colors leading-snug">
                    {post.data.title}
                  </h2>
                  {post.data.description && (
                    <p class="mt-2 text-sm text-soft-ink leading-relaxed">
                      {post.data.description}
                    </p>
                  )}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex gap-2 mt-4">
                      {post.data.tags.map((t) => (
                        <span class="text-xs px-2.5 py-1 rounded-full bg-gray-100 text-soft-ink">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </a>
            ))}
        </div>
      )
    }
  </div>
</BaseLayout>
