---
import { Image, getImage } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Resolve cover image for OG meta tags
let coverImageUrl, coverImageWidth, coverImageHeight;
if (post.data.coverImage) {
  const resolved = await getImage({ src: post.data.coverImage });
  coverImageUrl = resolved.src;
  coverImageWidth = resolved.attributes.width;
  coverImageHeight = resolved.attributes.height;
}
---

<BaseLayout
  title={`${post.data.title} — Shawn Han`}
  description={post.data.description}
  coverImageUrl={coverImageUrl}
  coverImageWidth={coverImageWidth}
  coverImageHeight={coverImageHeight}
  showSocialSidebar={true}
>
  <article>
    <a
      href="/blog"
      class="text-xs tracking-wide uppercase text-soft-ink hover:text-ink transition-colors"
    >
      &larr; Blog
    </a>

    <h1 class="font-serif text-4xl md:text-5xl font-semibold tracking-tight mt-6 mb-4 leading-tight">
      {post.data.title}
    </h1>

    <p class="text-sm text-soft-ink mb-8">
      {post.data.date.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </p>

    {post.data.coverImage && (
      <div class="mb-10 -mx-6 md:mx-0 rounded-none md:rounded-2xl overflow-hidden">
        <Image
          src={post.data.coverImage}
          alt={post.data.title}
          class="w-full"
        />
      </div>
    )}

    <Content />
  </article>
</BaseLayout>
