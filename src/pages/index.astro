---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Shawn Han"
  description="CMU stats & ML + CS student. Personal portfolio and sports analytics blog."
>
  <div class="py-16 md:py-24">
    <h1 class="font-serif text-5xl md:text-6xl font-semibold tracking-tight leading-tight text-ink">
      Stats, sports,<br />and the stories<br />between the lines.
    </h1>
    <p class="mt-6 text-lg text-soft-ink leading-relaxed max-w-lg">
      I'm Shawn Han — a CMU stats &amp; ML + CS student exploring the
      intersection of data science and sports analytics.
    </p>
    <div class="flex gap-3 mt-8">
      <a
        href="/blog"
        class="inline-flex items-center px-5 py-2.5 rounded-full bg-ink text-white text-sm font-medium hover:opacity-85 transition-opacity"
      >
        Read the blog
      </a>
      <a
        href="/projects"
        class="inline-flex items-center px-5 py-2.5 rounded-full border border-gray-300 text-sm font-medium hover:bg-white transition-colors"
      >
        Projects
      </a>
    </div>
  </div>
</BaseLayout>
