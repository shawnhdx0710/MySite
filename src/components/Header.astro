---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-gray-200/60 bg-cream/80 backdrop-blur-sm sticky top-0 z-10">
  <nav class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href="/" class="font-serif text-xl font-semibold tracking-tight hover:opacity-70 transition-opacity">
      Shawn Han
    </a>
    <div class="flex items-center gap-8">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm tracking-wide uppercase transition-colors hover:text-ink ${
            currentPath === href
              ? 'text-ink font-medium'
              : 'text-soft-ink'
          }`}
        >
          {label}
        </a>
      ))}
    </div>
  </nav>
</header>
